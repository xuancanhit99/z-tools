COMPOSE_PROJECT_NAME=hyperz
APP_ENV=local
LOG_LEVEL=info

FE_PORT=3000
FE_ORIGIN=http://localhost:3000
BE_PORT=8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_USE_MOCK_API=false
JWT_SECRET=hyperz-dev-jwt-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_SECRET=hyperz-dev-jwt-refresh-secret
AUTH_SEED_ENABLED=true
AUTH_SEED_EMAIL=admin@hyperz.local
AUTH_SEED_PASSWORD=admin123
AUTH_SEED_ROLE=admin

POSTGRES_PORT=5432
POSTGRES_DB=hyperz
POSTGRES_USER=hyperz
POSTGRES_PASSWORD=hyperz_dev_password
DATABASE_URL=postgresql://hyperz:hyperz_dev_password@postgres:5432/hyperz

REDIS_PORT=6379
REDIS_PASSWORD=hyperz_redis_password
REDIS_URL=redis://:hyperz_redis_password@redis:6379/0

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=hyperz-local
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123

# Deployment (scripts/deploy_vps.sh)
# These are intentionally blank by default; export before deploy.
DEPLOY_HOST=
DEPLOY_USER=
DEPLOY_PATH=
DEPLOY_SSH_PORT=22
DEPLOY_ENV_FILE=.env
DEPLOY_HEALTHCHECK_URL=http://127.0.0.1:8080/api/v1/health
DEPLOY_HEALTHCHECK_ATTEMPTS=20
DEPLOY_HEALTHCHECK_INTERVAL_SECONDS=5
DEPLOY_BE_IMAGE=hyperz-be:local
DEPLOY_FE_IMAGE=hyperz-fe:local
DEPLOY_BE_ROLLBACK_IMAGE=hyperz-be:rollback
DEPLOY_FE_ROLLBACK_IMAGE=hyperz-fe:rollback
